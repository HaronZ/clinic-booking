APP_ENV=local

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=clinic_booking
DB_USER=your_mysql_user
DB_PASS=your_mysql_password

# Used by tests/bootstrap.php — must NOT be the same as DB_NAME
TEST_DB_NAME=clinic_booking_test

# JWT — change to a 64-char random string before going to production
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_TTL_HOURS=12

# Email — set MAIL_ENABLED=1 and fill credentials to actually send
# For Gmail: create an App Password at myaccount.google.com/apppasswords
MAIL_ENABLED=0
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-16-char-app-password
MAIL_FROM=noreply@yourclinic.com
MAIL_FROM_NAME="Clinic Booking"
